# Ignore all files by default
**/*

# Except Google Apps Script source files and manifest
!appsscript.json
!*.js
!*.gs
!*.html

# Ignore package configuration and node modules
node_modules/**
package.json
package-lock.json

# Ignore Git directory and config
.git/**
.gitignore

# Ignore Clasp config and ignore files
.clasp.json
.claspignore

# Ignore Markdown documentation and local settings
**/*.md
.gemini/**
temp_pull/**

# Staging-only files (hapus baris berikut jika ingin push ke Production):
# Untuk exclude _Test.js dari production, jalankan: npm run deploy:prod
# (deploy:prod secara manual tidak push _Test.js karena hanya dibutuhkan saat staging)
# _Test.js   ← Uncomment baris ini untuk exclude dari SEMUA environment
